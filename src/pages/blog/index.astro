---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import Logo from "../../components/Logo.astro";

// Drafts show in dev, hide in production.
const posts = (await getCollection("blog", ({ data }) => import.meta.env.PROD ? !data.draft : true))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const fmt = (d: Date) => d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---
<Layout
  title="Blog — Plainvoice"
  description="Notes on invoicing, freelancing across borders, and building a genuinely free invoice app."
>
  <SiteHeader />
  <main class="blog-wrap">
    <header class="blog-head">
      <div class="sec-eyebrow">The Plainvoice blog</div>
      <h1 class="blog-h1">Notes on invoicing &amp; freelancing</h1>
      <p class="blog-lead">Product updates, freelancing tips, and the thinking behind a genuinely free invoice app.</p>
    </header>

    {posts.length === 0 ? (
      <p class="blog-empty">No posts yet — check back soon.</p>
    ) : (
      <ul class="post-list">
        {posts.map((post, i) => (
          <li class={`post-row${i === 0 ? " featured" : ""}`}>
            <a href={`/blog/${post.id}`}>
              <div class="post-meta">
                <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
                {post.data.draft && <span class="post-draft">Draft</span>}
              </div>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="post-tags">{post.data.tags.map((t) => <span class="pill">{t}</span>)}</div>
              )}
              <span class="post-more">Read <span aria-hidden="true">→</span></span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </main>

  <footer class="site">
    <div class="blog-foot foot-in">
      <Logo size={26} />
      <div class="foot-note">Unlimited free core · your data stays on your device</div>
    </div>
  </footer>
</Layout>
