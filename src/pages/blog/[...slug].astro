---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import Logo from "../../components/Logo.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => import.meta.env.PROD ? !data.draft : true);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, tags, author } = post.data;
const fmt = (d: Date) => d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });

const all = (await getCollection("blog", ({ data }) => import.meta.env.PROD ? !data.draft : true))
  .sort((a, b) => a.data.pubDate.getTime() - b.data.pubDate.getTime());
// Ledger numbering: oldest post is ENTRY № 01.
const entryNo = String(all.findIndex((p) => p.id === post.id) + 1).padStart(2, "0");

// Recent entries (newest first, excluding this one).
const recent = [...all]
  .reverse()
  .filter((p) => p.id !== post.id)
  .slice(0, 3);
const recentNo = (p: (typeof all)[number]) => String(all.findIndex((x) => x.id === p.id) + 1).padStart(2, "0");
---
<Layout
  title={`${title} — Plainvoice`}
  description={description}
  ogType="article"
  publishedTime={pubDate.toISOString()}
  modifiedTime={updatedDate?.toISOString()}
>
  <SiteHeader />
  <main class="post-wrap">
    <a class="bl-back mono" href="/blog">← The ledger</a>
    <article>
      <header class="bl-post-head">
        <div class="bl-meta mono">
          <span class="bl-no">Entry № {entryNo}</span>
          <span class="bl-dots"></span>
          <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
          <span>· {author}</span>
          {updatedDate && <span>· updated {fmt(updatedDate)}</span>}
        </div>
        <h1>{title}</h1>
        <p class="post-desc">{description}</p>
        {tags.length > 0 && (
          <div class="post-tags">{tags.map((t) => <span class="pill">{t}</span>)}</div>
        )}
      </header>
      <div class="prose">
        <Content />
      </div>
    </article>

    {recent.length > 0 && (
      <section class="bl-more">
        <div class="bl-more-head">
          <h2 class="mono">More from the ledger</h2>
          <a class="mono" href="/blog">All entries →</a>
        </div>
        <ul class="bl-list">
          {recent.map((p) => (
            <li class="bl-row bl-row-sm">
              <a href={`/blog/${p.id}`}>
                <div class="bl-meta mono">
                  <span class="bl-no">Entry № {recentNo(p)}</span>
                  <span class="bl-dots"></span>
                  <time datetime={p.data.pubDate.toISOString()}>{fmt(p.data.pubDate)}</time>
                </div>
                <h2>{p.data.title}</h2>
                <p>{p.data.description}</p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <div class="bl-cta">
      <div>
        <h3>Ready to send an invoice?</h3>
        <p>Unlimited invoices, real PDF export, no signup — free forever.</p>
      </div>
      <a class="btn btn-cream" href="/new">Create an invoice →</a>
    </div>
  </main>

  <footer class="site">
    <div class="blog-foot lp-foot">
      <div class="lp-foot-brand">
        <Logo size={26} />
        <div class="foot-note">Unlimited free core · your data stays on your device</div>
      </div>
      <div class="lp-foot-links mono">
        <a href="/">HOME</a>
        <a href="/new">OPEN THE EDITOR</a>
      </div>
    </div>
  </footer>
</Layout>
