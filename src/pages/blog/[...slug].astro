---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import Logo from "../../components/Logo.astro";
import { CONTACT_MAILTO } from "../../lib/links";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => import.meta.env.PROD ? !data.draft : true);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, tags, author } = post.data;
const fmt = (d: Date) => d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
const section = tags[0] ?? "Feature";

// FAQPage schema — parsed from a "## Frequently Asked Questions" section in the
// post body (### = question, following text = answer), so the structured data
// always matches the visible content and any future post with an FAQ gets it.
function stripMd(s: string): string {
  return s
    .replace(/\[([^\]]+)\]\([^)]*\)/g, "$1") // [text](url) -> text
    .replace(/[*_`]/g, "")                    // bold/italic/code marks
    .replace(/\s+/g, " ")
    .trim();
}
function extractFaqs(md: string): { q: string; a: string }[] {
  const sec = md.match(/##\s+Frequently Asked Questions\s*([\s\S]*?)(?=\n##\s|$)/i);
  if (!sec) return [];
  const out: { q: string; a: string }[] = [];
  const re = /###\s+(.+?)\n([\s\S]*?)(?=\n###\s|$)/g;
  let m: RegExpExecArray | null;
  while ((m = re.exec(sec[1])) !== null) {
    const q = stripMd(m[1]); const a = stripMd(m[2]);
    if (q && a) out.push({ q, a });
  }
  return out;
}
const faqs = extractFaqs(post.body ?? "");
const faqLd = faqs.length
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: faqs.map((f) => ({
        "@type": "Question",
        name: f.q,
        acceptedAnswer: { "@type": "Answer", text: f.a },
      })),
    }
  : null;

// Other recent stories (newest first, excluding this one).
const recent = (await getCollection("blog", ({ data }) => import.meta.env.PROD ? !data.draft : true))
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---
<Layout
  title={`${title} — Plainvoice`}
  description={description}
  ogType="article"
  publishedTime={pubDate.toISOString()}
  modifiedTime={updatedDate?.toISOString()}
>
  <SiteHeader />
  <main class="gz-wrap gz-article">
    <!-- mini masthead links back to the front page -->
    <div class="gz-mini"><a class="mono" href="/blog">The Plainvoice Gazette</a></div>

    <article>
      <header class="gz-art-head">
        <div class="gz-kicker mono">{section} · {fmt(pubDate)}</div>
        <h1>{title}</h1>
        <p class="gz-standfirst">{description}</p>
        <div class="gz-byline mono">
          By {author}{updatedDate && <span> · updated {fmt(updatedDate)}</span>}
        </div>
      </header>
      <div class="prose gz-prose">
        <Content />
      </div>
    </article>
    {faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}

    {recent.length > 0 && (
      <section class="gz-more">
        <div class="gz-more-head mono">Also in the Gazette</div>
        <div class="gz-cols gz-cols-tight">
          {recent.map((p) => (
            <article class="gz-story">
              <a href={`/blog/${p.id}`}>
                <div class="gz-kicker mono">{fmt(p.data.pubDate)}</div>
                <h3>{p.data.title}</h3>
                <p>{p.data.description}</p>
                <span class="gz-cont mono">Read →</span>
              </a>
            </article>
          ))}
        </div>
      </section>
    )}

    <a class="gz-ad gz-ad-wide" href="/new">
      <div class="gz-ad-lab mono">Advertisement</div>
      <div class="gz-ad-h">Send an invoice in two minutes.</div>
      <p>No signup · no caps · works offline. Plainvoice, the honest invoice app — $0, forever.</p>
      <span class="btn btn-primary btn-sm">Open the editor →</span>
    </a>
  </main>

  <footer class="site">
    <div class="blog-foot lp-foot">
      <div class="lp-foot-brand">
        <Logo size={26} />
        <div class="foot-note">Unlimited free core · your data stays on your device</div>
      </div>
      <div class="lp-foot-links mono">
        <a href="/">HOME</a>
        <a href="/new">OPEN THE EDITOR</a>
        <a href={CONTACT_MAILTO}>CONTACT</a>
      </div>
    </div>
  </footer>
</Layout>
