---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import Logo from "../../components/Logo.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => import.meta.env.PROD ? !data.draft : true);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, tags, author } = post.data;
const fmt = (d: Date) => d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });

// Recent articles (newest first, excluding this one).
const recent = (await getCollection("blog", ({ data }) => import.meta.env.PROD ? !data.draft : true))
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---
<Layout
  title={`${title} — Plainvoice`}
  description={description}
  ogType="article"
  publishedTime={pubDate.toISOString()}
  modifiedTime={updatedDate?.toISOString()}
>
  <SiteHeader />
  <main class="post-wrap">
    <a class="post-back" href="/blog">← All posts</a>
    <article>
      <header class="post-header">
        <div class="post-meta">
          <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
          <span>· {author}</span>
          {updatedDate && <span>· updated {fmt(updatedDate)}</span>}
        </div>
        <h1>{title}</h1>
        <p class="post-desc">{description}</p>
        {tags.length > 0 && (
          <div class="post-tags">{tags.map((t) => <span class="pill">{t}</span>)}</div>
        )}
      </header>
      <div class="prose">
        <Content />
      </div>
    </article>

    {recent.length > 0 && (
      <section class="more-posts">
        <div class="more-posts-head">
          <h2>More from the blog</h2>
          <a href="/blog">All posts →</a>
        </div>
        <ul>
          {recent.map((p) => (
            <li>
              <a href={`/blog/${p.id}`}>
                <time datetime={p.data.pubDate.toISOString()}>{fmt(p.data.pubDate)}</time>
                <span class="mp-title">{p.data.title}</span>
                <span class="mp-desc">{p.data.description}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <div class="post-cta">
      <h3>Ready to send an invoice?</h3>
      <p>Unlimited invoices, real PDF export, no signup.</p>
      <a class="btn btn-primary" href="/new">Create an invoice — free</a>
    </div>
  </main>

  <footer class="site">
    <div class="blog-foot foot-in">
      <Logo size={26} />
      <div class="foot-note">Unlimited free core · your data stays on your device</div>
    </div>
  </footer>
</Layout>
