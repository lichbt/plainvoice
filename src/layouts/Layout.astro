---
import "../styles/global.css";
interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  ogType?: "website" | "article";
  publishedTime?: string; // ISO, for article OG
  modifiedTime?: string;
}
const {
  title = "Plainvoice — invoicing that's actually free",
  description = "Unlimited invoices, clients and estimates — free, forever, no caps. AI is the only thing you ever pay for, and only when you want it.",
  noindex = false,
  ogType = "website",
  publishedTime,
  modifiedTime,
} = Astro.props;

const siteName = "Plainvoice";
// Astro.site is set in astro.config; canonical = site + current path.
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.href;
// Social share card (1200×630) — regenerate with: node scripts/gen-assets.mjs
const ogImage = Astro.site ? new URL("/og.png", Astro.site).href : "/og.png";
const jsonLd = ogType === "article"
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: title,
      description,
      url: canonical,
      datePublished: publishedTime,
      dateModified: modifiedTime ?? publishedTime,
      publisher: { "@type": "Organization", name: siteName },
    }
  : {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: siteName,
      applicationCategory: "BusinessApplication",
      operatingSystem: "Web, iOS, Android",
      description,
      url: Astro.site?.href ?? canonical,
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    };
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Self-hosted fonts (see src/styles/fonts.css). Preload the two most-visible
         latin faces so they're ready at first paint — no third-party request, no
         render-blocking, no swap reflow. -->
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/ieVn2YZDLWuGJpnzaiwFXS9tYtpd59A.woff2" />
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/6NU78FyLNQOQZAnv9bYEvDiIdE9Ea92uemAk_WBq8U_9v0c2Wa0KxC9TeA.woff2" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="e8YpxlBQla7rUl-b32LTszya25i4qJlRO6VtFKrrmfs" />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />

    <!-- Open Graph (LinkedIn, Slack, iMessage, Facebook) -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Plainvoice — invoicing that's actually free" />
    {ogType === "article" && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {ogType === "article" && (modifiedTime || publishedTime) && <meta property="article:modified_time" content={modifiedTime ?? publishedTime} />}

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="alternate" type="application/rss+xml" title="Plainvoice blog" href="/rss.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#1E5B41" />
    <link rel="apple-touch-icon" href="/icon-192.png" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    {/* Google Analytics (GA4) — production only. Loaded LAZILY (on idle-after-load
        or first interaction, whichever comes first) so gtag.js doesn't execute in
        the critical window and inflate Total Blocking Time. Still fires for real
        visitors; just kept off the page-load main thread. */}
    {import.meta.env.PROD && (
      <script is:inline define:vars={{ GA_ID: "G-1MZ3QYLWNW" }}>
        {`
        (function () {
          var started = false;
          function loadGA() {
            if (started) return; started = true;
            var s = document.createElement("script");
            s.async = true;
            s.src = "https://www.googletagmanager.com/gtag/js?id=" + GA_ID;
            document.head.appendChild(s);
            window.dataLayer = window.dataLayer || [];
            window.gtag = function () { dataLayer.push(arguments); };
            gtag("js", new Date());
            gtag("config", GA_ID);
          }
          var idle = function () {
            ("requestIdleCallback" in window)
              ? requestIdleCallback(loadGA, { timeout: 3000 })
              : setTimeout(loadGA, 2000);
          };
          (document.readyState === "complete") ? idle() : addEventListener("load", idle, { once: true });
          ["scroll", "pointerdown", "keydown", "touchstart"].forEach(function (ev) {
            addEventListener(ev, loadGA, { once: true, passive: true });
          });
        })();
        `}
      </script>
    )}
  </head>
  <body>
    <slot />
    {import.meta.env.PROD && (
      <script is:inline>
        if ("serviceWorker" in navigator) {
          addEventListener("load", () => navigator.serviceWorker.register("/sw.js").catch(() => {}));
        }
      </script>
    )}
  </body>
</html>
