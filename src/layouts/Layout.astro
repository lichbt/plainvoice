---
import "../styles/global.css";
interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  ogType?: "website" | "article";
  publishedTime?: string; // ISO, for article OG
  modifiedTime?: string;
}
const {
  title = "Plainvoice — invoicing that's actually free",
  description = "Unlimited invoices, clients and estimates — free, forever, no caps. AI is the only thing you ever pay for, and only when you want it.",
  noindex = false,
  ogType = "website",
  publishedTime,
  modifiedTime,
} = Astro.props;

const siteName = "Plainvoice";
// Astro.site is set in astro.config; canonical = site + current path.
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.href;
// Social share card (1200×630) — regenerate with: node scripts/gen-assets.mjs
const ogImage = Astro.site ? new URL("/og.png", Astro.site).href : "/og.png";
const jsonLd = ogType === "article"
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: title,
      description,
      url: canonical,
      datePublished: publishedTime,
      dateModified: modifiedTime ?? publishedTime,
      publisher: { "@type": "Organization", name: siteName },
    }
  : {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: siteName,
      applicationCategory: "BusinessApplication",
      operatingSystem: "Web, iOS, Android",
      description,
      url: Astro.site?.href ?? canonical,
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    };
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="e8YpxlBQla7rUl-b32LTszya25i4qJlRO6VtFKrrmfs" />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />

    <!-- Open Graph (LinkedIn, Slack, iMessage, Facebook) -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Plainvoice — invoicing that's actually free" />
    {ogType === "article" && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {ogType === "article" && (modifiedTime || publishedTime) && <meta property="article:modified_time" content={modifiedTime ?? publishedTime} />}

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="alternate" type="application/rss+xml" title="Plainvoice blog" href="/rss.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#1E5B41" />
    <link rel="apple-touch-icon" href="/icon-192.png" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    {/* Google Analytics (GA4) — production only, so dev sessions don't pollute the data */}
    {import.meta.env.PROD && (
      <>
        <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-1MZ3QYLWNW"></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag("js", new Date());
          gtag("config", "G-1MZ3QYLWNW");
        </script>
      </>
    )}
  </head>
  <body>
    <slot />
    {import.meta.env.PROD && (
      <script is:inline>
        if ("serviceWorker" in navigator) {
          addEventListener("load", () => navigator.serviceWorker.register("/sw.js").catch(() => {}));
        }
      </script>
    )}
  </body>
</html>
